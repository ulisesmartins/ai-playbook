{
  "mcpServers": {
    "gmail": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gmail"],
      "env": {
        "GMAIL_CLIENT_ID": "your-oauth-client-id-here",
        "GMAIL_CLIENT_SECRET": "your-oauth-client-secret-here",
        "GMAIL_REFRESH_TOKEN": "your-refresh-token-here"
      }
    }
  }
}
